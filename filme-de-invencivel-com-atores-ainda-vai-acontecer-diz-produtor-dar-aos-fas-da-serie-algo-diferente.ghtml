    }
  }
</style> <div class="header-principal header-navegacao-color"> <div class="grid-12 header-navegacao-container row"> <div class="area-principal column"> <div class="header-navegacao-left"> <a class="logo-area" href="https://g1.globo.com/" title="g1"> <div class="logo"><svg fill="none" viewbox="0 0 42 42" xmlns="http://www.w3.org/2000/svg"><path d="M30.167 4.866L38.12.134C38.99-.295 40 .345 40 1.512V30.31c0 .54-.585 1.133-1.307 1.133h-3.655a1.315 1.315 0 01-1.306-1.323V9.352l-2.444 1.458c-.868.426-1.855-.237-1.855-1.213V6.055c0-.507.285-.968.734-1.19zM14.11 25.831c-3.246 0-5.977-2.607-5.977-6.415 0-3.86 2.73-6.416 5.977-6.416 3.246 0 5.925 2.555 5.925 6.416 0 3.808-2.68 6.415-5.925 6.415zm7.368-18.463c-.773 0-1.236.469-1.236 1.251v1.356c-1.392-1.722-3.968-3.026-6.545-3.026C7.411 6.95 2 12.374 2 19.467c0 7.094 5.1 11.997 11.542 11.997a8.67 8.67 0 006.389-2.764c-.05 4.954-2.627 7.198-7.059 7.198-2.37 0-4.586-.731-7.161-2.4-.67-.469-1.443-.313-1.804.418L2.36 36.993c-.36.73-.257 1.408.464 1.877C6.02 40.956 9.782 42 13.028 42c8.502 0 13.19-4.643 13.19-15.335V8.62c0-.782-.463-1.251-1.236-1.251h-3.504z" fill="#fff"/></svg></div> </a> </div> <div class="header-navegacao-center"> <a class="logo-area" href="https://g1.globo.com/" title="g1"> <div class="logo"><svg fill="none" viewbox="0 0 42 42" xmlns="http://www.w3.org/2000/svg"><path d="M30.167 4.866L38.12.134C38.99-.295 40 .345 40 1.512V30.31c0 .54-.585 1.133-1.307 1.133h-3.655a1.315 1.315 0 01-1.306-1.323V9.352l-2.444 1.458c-.868.426-1.855-.237-1.855-1.213V6.055c0-.507.285-.968.734-1.19zM14.11 25.831c-3.246 0-5.977-2.607-5.977-6.415 0-3.86 2.73-6.416 5.977-6.416 3.246 0 5.925 2.555 5.925 6.416 0 3.808-2.68 6.415-5.925 6.415zm7.368-18.463c-.773 0-1.236.469-1.236 1.251v1.356c-1.392-1.722-3.968-3.026-6.545-3.026C7.411 6.95 2 12.374 2 19.467c0 7.094 5.1 11.997 11.542 11.997a8.67 8.67 0 006.389-2.764c-.05 4.954-2.627 7.198-7.059 7.198-2.37 0-4.586-.731-7.161-2.4-.67-.469-1.443-.313-1.804.418L2.36 36.993c-.36.73-.257 1.408.464 1.877C6.02 40.956 9.782 42 13.028 42c8.502 0 13.19-4.643 13.19-15.335V8.62c0-.782-.463-1.251-1.236-1.251h-3.504z" fill="#fff"/></svg></div> </a> <div class="header-title-content"> <span class="header-title"> <a class="header-editoria--link" href="http://g1.globo.com/pop-arte/" title="Pop & Arte">Pop & Arte</a> </span> </div> </div> <div class="header-navegacao-right"> <div id="codex-touchpoint-login" class="codex-touchpoint-login" data-props="[]">
  
</div> </div> </div> </div> </div> <span class="gui-color-primary-bg header-subtitle header-navegacao-color"> <span class="header-subeditoria--link" title="Home de Cinema">Cinema</span> </span> <div class="banner"> <div class="opec-area opec-right"> <div class="opec-internal"> <div id="banner_insert" class="tag-manager-publicidade-container"></div> </div> </div> </div> </header> </div> <script>
